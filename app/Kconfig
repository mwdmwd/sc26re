# SPDX-License-Identifier: AGPL-3.0-or-later

mainmenu "SC26re firmware"

menu "SC26re application"

config IBEX_BUILD_TIMESTAMP
	hex "Firmware build timestamp"
	default 0xf0550000
	help
	  Value exposed through the build_timestamp numeric attribute and used in
	  the packaged Ibex firmware filename. Makefile builds default this to
	  0xf0550000 plus the repository build number.

config IBEX_FIRMWARE_IDENTITY
	string "Custom firmware identity"
	default "SC26re"
	help
	  Human-readable identity embedded in the application and shown by the
	  steamctl status shell command.

config SC26RE_ALLOW_NORDIC_NONFREE
	bool "Allow Nordic-licensed radio components"
	default n
	help
	  Enable firmware options that link nonfree Nordic-5-Clause
	  components from nRF Connect SDK, including MPSL, SoftDevice
	  Controller, and the NCS ESB subsystem. Leave this disabled for
	  redistributable AGPL-only firmware builds.

config GPIO_GREENPAK
	bool "Valve GreenPAK input GPIO driver"
	default y if DT_HAS_VALVE_SLG4L48185_GPIO_ENABLED
	depends on GPIO && I2C && DT_HAS_VALVE_SLG4L48185_GPIO_ENABLED
	help
	  GPIO controller for the SLG4L48185 used by the Ibex board. This
	  implements only GPIO input and does not program GreenPAK config
	  NVM (which is probably done at the factory anyway).

config IBEX_BLE
	bool "Bluetooth LE HID transport"
	default y
	depends on BT && SC26RE_ALLOW_NORDIC_NONFREE
	help
	  Include the NCS Bluetooth HID transport for BLE support.

config IBEX_USB_HID
	bool "USB HID transport"
	default y if BOARD_STEAM_CONTROLLER_IBEX
	depends on BOARD_STEAM_CONTROLLER_IBEX && USB_DEVICE_HID && !IBEX_USB_CDC_ONLY
	help
	  Include the USB HID transport for Valve HID support over USB.

config IBEX_USB_CDC_ONLY
	bool "Use USB only for the CDC-ACM shell"
	default n
	depends on BOARD_STEAM_CONTROLLER_IBEX && USB_DEVICE_STACK
	help
	  Diagnostic mode for radio bring-up: enumerate only the CDC-ACM shell
	  over USB, with no Valve HID interface. This keeps Steam from opening
	  the USB controller while the shell can be used over the USB cable.

config IBEX_ESB
	bool "Enhanced ShockBurst transport (puck support)"
	default n
	select ENTROPY_GENERATOR
	help
	  Include the ESB transport for Valve HID support over Enhanced ShockBurst.
	  Also known as "puck support".

choice SC26RE_ESB_BACKEND
	prompt "ESB radio backend"
	default SC26RE_ESB_BACKEND_NCS if SC26RE_ALLOW_NORDIC_NONFREE
	default SC26RE_ESB_BACKEND_DIRECT
	depends on IBEX_ESB

config SC26RE_ESB_BACKEND_DIRECT
	bool "Direct NRF_RADIO backend"
	depends on SOC_NRF52833
	help
	  Use direct nRF RADIO programming to avoid proprietary Nordic ESB/MPSL libraries
	  for ESB.

config SC26RE_ESB_BACKEND_NCS
	bool "Nordic NCS ESB backend"
	depends on SC26RE_ALLOW_NORDIC_NONFREE
	select ESB
	select DYNAMIC_INTERRUPTS
	select DYNAMIC_DIRECT_INTERRUPTS
	select MPSL_DYNAMIC_INTERRUPTS
	select ESB_DYNAMIC_INTERRUPTS
	help
	  Use the nRF Connect SDK ESB subsystem. This includes nonfree
	  Nordic-5-Clause components through ESB/MPSL so the resulting
	  firmware is not redistributable.

endchoice

if SC26RE_ESB_BACKEND_NCS

config ESB_MAX_PAYLOAD_LENGTH
	default 128

config ESB_TX_FIFO_SIZE
	default 2

config ESB_RX_FIFO_SIZE
	default 8

config ESB_PIPE_COUNT
	default 1

endif

config IBEX_ACCELEROMETER
	bool "Include accelerometer data when accel0 is available"
	default y
	depends on SENSOR

config IBEX_ANALOG_INPUTS
	bool "Include Ibex stick and trigger ADC inputs"
	default y if BOARD_STEAM_CONTROLLER_IBEX
	depends on ADC
	help
	  Scan the six Ibex SAADC channels and include them in HID reports.

config IBEX_OLYMPUS
	bool "Include Ibex Olympus touchpads"
	default y if BOARD_STEAM_CONTROLLER_IBEX
	depends on I2C && GPIO && DT_HAS_VALVE_OLYMPUS_ENABLED
	help
	  Configure the Olympus touch controller and include touchpad data in HID reports.

config HAPTICS_PWM_NRF
	bool "nRF PWM button beep backend"
	default y if BOARD_BBC_MICROBIT_V2
	depends on PWM
	help
	  Short debug beep on button press through the micro:bit piezo.

config IBEX_RGBW_LED
	bool "RGBW LED control"
	default y if BOARD_STEAM_CONTROLLER_IBEX
	depends on LED && PWM
	help
	  Control the four-channel RGBW LED on the controller face.

config IBEX_BATTERY
	bool "Ibex battery and charger reporting"
	default y if DT_HAS_MONOLITHICPOWER_MP2733_ENABLED
	depends on I2C && DT_HAS_MONOLITHICPOWER_MP2733_ENABLED
	help
	  Poll the MP2733 charger/fuel-gauge and expose battery level over HID/BLE BAS.

endmenu

source "Kconfig.zephyr"
